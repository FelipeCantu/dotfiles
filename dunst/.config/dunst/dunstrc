 [global]
	width = 300
	height = 300
	origin = top-right
	offset = 10x50
	frame_color = "#88c0d0"
	font = monospace 10

 [urgency_low]
	background = "#2e3440"
	foreground = "#d8dee9"
	timeout = 5

 [urgency_normal]
	background = "#2e3440"
	foreground = "#d8dee9"
	timeout = 5

 [urgency_critical]
	background = "#2e3440"
	foreground = "#bf616a"
	frame_color = "#bf616a"
	timeout = 0
