general {
	colors = true
	interval = 5
	color_good = "#a3be8c"
	color_degraded = "#ebcb8b"
	color_bad = "#bf616a"
}

order += "cpu_usage"
order += "memory"
order += "load"
order += "disk /"
order += "tztime local"

cpu_usage {
	format = "CPU: %usage"
}

memory {
	format = "RAM %used / %total"
	threshold_degraded = "10%"
}

load {
	format = "Load: %1min"
}

disk "/" {
	format = "Disk: %avail free"
}

tztime local {
	format = "%Y-%m-%d %H:%M:%S"
}
